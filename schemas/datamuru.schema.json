{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schema.datamuru.dev/0.2/datamuru.schema.json",
  "title": "DataMuru Root Configuration",
  "type": "object",
  "required": ["project", "environments", "default_environment", "features", "state", "provider"],
  "properties": {
    "project": {
      "type": "object",
      "required": ["name", "version", "edition", "provider"],
      "properties": {
        "name": {"type": "string", "minLength": 1},
        "version": {"type": "string", "minLength": 1},
        "description": {"type": "string"},
        "edition": {"enum": ["open-source", "enterprise"]},
        "provider": {"type": "string", "minLength": 1}
      },
      "additionalProperties": false
    },
    "environments": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "config"],
        "properties": {
          "name": {"type": "string", "minLength": 1},
          "config": {"type": "string", "minLength": 1}
        },
        "additionalProperties": false
      }
    },
    "default_environment": {"type": "string", "minLength": 1},
    "features": {
      "type": "object",
      "properties": {
        "governance": {"type": "boolean"},
        "data_mesh": {"type": "boolean"},
        "ingestion": {"type": "boolean"},
        "modeling": {"type": "boolean"},
        "observability": {"type": "boolean"},
        "compliance_reporting": {"type": "boolean"},
        "multi_workspace": {"type": "boolean"},
        "hosted_control_plane": {"type": "boolean"},
        "identity_management": {"type": "boolean"}
      },
      "additionalProperties": false
    },
    "state": {
      "type": "object",
      "required": ["backend", "path"],
      "properties": {
        "backend": {"enum": ["local", "s3", "azure_blob", "gcs"]},
        "path": {"type": "string", "minLength": 1}
      },
      "additionalProperties": false
    },
    "provider": {
      "type": "object",
      "required": ["name", "cloud", "config"],
      "properties": {
        "name": {"type": "string", "minLength": 1},
        "cloud": {"enum": ["azure", "aws", "gcp"]},
        "config": {"type": "string", "minLength": 1}
      },
      "additionalProperties": false
    },
    "ai": {"type": "object"},
    "enterprise": {
      "type": "object",
      "properties": {
        "activation": {
          "type": "object",
          "properties": {
            "organization": {"type": "string", "minLength": 1},
            "contact_email": {"type": "string", "minLength": 1},
            "control_plane_url": {"type": "string", "minLength": 1},
            "tenant_id": {"type": "string", "minLength": 1},
            "deployment_region": {"type": "string", "minLength": 1},
            "license_key_env": {"type": "string", "minLength": 1},
            "purchase_reference": {"type": "string"},
            "support_plan": {"type": "string"}
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
